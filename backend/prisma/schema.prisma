generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// STRICT STATUS ENUMS
// ==========================================

enum FollowUpStatus {
  PENDING
  CONTACTED
  INTERESTED
  FOLLOWUP_REQUIRED
  CONVERTED
  CLOSED
}

enum AdminRole {
  SUPER_ADMIN
  MANAGER
  VIEWER
}

enum AdminStatus {
  ACTIVE
  SUSPENDED
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum UserStatus {
  NEW
  ACTIVE
  VIP
  BLOCKED
  EXPIRED
}

enum AccountType {
  USER
  TENANT
  SYSTEM
}

enum EntryType {
  DEBIT
  CREDIT
}

enum TradeType {
  BUY
  SELL
}

enum TradeStatus {
  ACTIVE
  CLOSED
  CANCELLED
}

enum PaymentType {
  USDT
  UPI
  BANK
}

enum PaymentStatus {
  PENDING
  VERIFIED
  APPROVED
  REJECTED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
  FAILED
}

enum ReferralStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
  REJECTED
}

enum LedgerType {
  DEPOSIT
  WITHDRAWAL
  REFERRAL_COMMISSION
  PROFIT_DISTRIBUTION
  PROFIT_REVERSAL
  ADJUSTMENT
}

enum DistributionStatus {
  PENDING
  COMPLETED
  REVERSED
  FAILED
}

enum OtpStatus {
  PENDING
  VERIFIED
  EXPIRED
}

enum TransactionGroupType {
  DEPOSIT
  TRADE_PROFIT
  TRADE_LOSS
  WITHDRAWAL
  PLATFORM_FEE
  REFERRAL_PAYOUT
  SYSTEM_ADJUSTMENT
}

// ==========================================
// NOTIFICATION ENUMS
// ==========================================

enum NotificationPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationCategory {
  TRADE
  PAYMENT
  WITHDRAWAL
  SUBSCRIPTION
  PROFIT
  REPORT
  SECURITY
  SUPPORT
  SYSTEM
}

enum NotificationAudience {
  ALL_USERS
  ACTIVE_USERS
  EXPIRED_USERS
  VIP_USERS
  CLUB_PLAN
  INDIVIDUAL_PLAN
  ADMINS
  CUSTOM
}

enum BroadcastStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  SENDING
  PARTIALLY_FAILED
  SENT
  CANCELLED
  REJECTED
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  OPENED
  CLICKED
}

enum NotificationChannel {
  BELL
  PUSH
  EMAIL
  SOCKET
  TOAST
  SMS
}

enum NotificationStatus {
  UNREAD
  READ
  ARCHIVED
  DELETED
}

enum NotificationScheduleStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum NotificationEvent {
  PAYMENT_SUBMITTED
  PAYMENT_APPROVED
  PAYMENT_REJECTED

  DEPOSIT_APPROVED
  DEPOSIT_REJECTED

  WITHDRAWAL_REQUESTED
  WITHDRAWAL_APPROVED
  WITHDRAWAL_REJECTED

  TRADE_PUBLISHED
  TRADE_OPENED
  TRADE_CLOSED
  TRADE_CANCELLED

  TAKE_PROFIT_HIT
  STOP_LOSS_HIT
  SIGNAL_UPDATED

  PROFIT_DISTRIBUTED

  PLAN_ACTIVATED
  PLAN_EXPIRING
  PLAN_EXPIRED
  PLAN_UPGRADED
  PLAN_DOWNGRADED

  REPORT_READY

  NEW_LOGIN
  PASSWORD_CHANGED
  EMAIL_CHANGED
  ACCOUNT_BLOCKED
  TWO_FACTOR_ENABLED
  TWO_FACTOR_DISABLED

  TICKET_CREATED
  TICKET_REPLIED
  TICKET_CLOSED

  ADMIN_LOGIN
  ADMIN_CREATED
  ADMIN_REMOVED
  SYSTEM
}

// ==========================================
// IDENTITY LAYER MODELS
// ==========================================

model Admin {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  passwordHash    String
  role            AdminRole        @default(VIEWER)
  status          AdminStatus      @default(ACTIVE)
  permissions     Json             // structured json e.g. { "users": ["read", "write"] }
  createdBy       String?          // UUID of super admin creator
  lastLoginAt     DateTime?
  lastLoginIP     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  securityEvents  SecurityEvent[]

  // Notification relations
  notifications           Notification[]
  deviceTokens            DeviceToken[]
  broadcastsCreated       NotificationBroadcast[] @relation("BroadcastCreated")
  broadcastsApproved      NotificationBroadcast[] @relation("BroadcastApproved")
  broadcastsCancelled     NotificationBroadcast[] @relation("BroadcastCancelled")
  notificationActions     NotificationAction[]
  notificationAudits      NotificationAdminAudit[] @relation("AdminNotificationAudits")

  @@index([email])
}

model Partner {
  id                String         @id @default(uuid())
  slug              String         @unique // e.g. "alpha-traders"
  name              String
  companyName       String
  email             String         @unique
  passwordHash      String
  profitSharePct    Decimal        @db.Decimal(5, 2) // Commission percentage e.g. 30.00%
  maxAllowedPct     Decimal        @db.Decimal(5, 2)
  domain            String         @unique
  logo              String?        // logo URL or brand initials
  status            PartnerStatus  @default(ACTIVE)
  lastLoginAt       DateTime?
  lastLoginIP       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  
  // Relations
  users             User[]
  ledgerEntries     LedgerEntry[]
  investmentPlans   InvestmentPlan[]
  userInvestments   UserInvestment[]

  // Notification relations
  notifications              Notification[]
  notificationSchedules      NotificationSchedule[]
  notificationBroadcasts     NotificationBroadcast[]
  notificationAnalytics      NotificationAnalytics[]
  notificationTemplates      NotificationTemplate[]

  @@index([domain])
}

model User {
  id             String           @id @default(uuid())
  partnerId      String
  name           String
  email          String
  phone          String?          @db.VarChar(20)
  passwordHash   String
  status         UserStatus       @default(NEW)
  isDeleted      Boolean          @default(false)
  lastLoginAt    DateTime?
  lastLoginIP    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  referralCode   String           @unique
  referredBy     String?
  campaignCode   String?

  isVerified     Boolean          @default(false)
  otpCode        String?
  otpExpiresAt   DateTime?

  // Relations
  referrer       User?            @relation("UserReferrals", fields: [referredBy], references: [id])
  referredUsers  User[]           @relation("UserReferrals")
  referralsMade    Referral[] @relation("ReferrerToReferral")
  referralsGotten  Referral[] @relation("ReferredToReferral")
  partner        Partner          @relation(fields: [partnerId], references: [id])
  wallet         Wallet?
  payments       Payment[]
  paymentInitiations PaymentInitiation[]
  withdrawals    Withdrawal[]
  trades         Trade[]
  ledgerEntries  LedgerEntry[]
  securityEvents SecurityEvent[]
  profitDistributions ProfitDistribution[]
  investments    UserInvestment[]
  generatedReports GeneratedReport[]
  userPlans      UserPlan[]

  // Notification relations
  deviceTokens   DeviceToken[]
  notifications  Notification[]
  notificationReads NotificationRead[]
  notificationPreferences UserNotificationPreference[]
  notificationActions NotificationAction[]

  // Simulation settings
  autoTrading    Boolean          @default(false)
  riskSetting    String           @default("MEDIUM")

  // Uniqueness and tenant isolation indexes
  @@unique([partnerId, email])
  
  @@index([partnerId])
  @@index([partnerId, id])
  @@index([partnerId, email])
  @@index([partnerId, createdAt])
}

// ==========================================
// DOUBLE-ENTRY LEDGER & CACHED WALLETS
// ==========================================

model Wallet {
  id                 String     @id @default(uuid())
  userId             String     @unique
  realizedBalance    Decimal    @default(0.0000) @db.Decimal(18, 4) // Cash available for withdrawal
  unrealizedBalance  Decimal    @default(0.0000) @db.Decimal(18, 4) // Escrow/floating trades margin
  currentEquity      Decimal    @default(0.0000) @db.Decimal(18, 4) // current_equity
  availableBalance   Decimal    @default(0.0000) @db.Decimal(18, 4) // available_balance
  pendingWithdrawals Decimal    @default(0.0000) @db.Decimal(18, 4) // pending_withdrawals
  totalWithdrawn     Decimal    @default(0.0000) @db.Decimal(18, 4) // total_withdrawn
  currency           String     @default("INR")
  version            Int        @default(1) // Version field for optimistic concurrency locking
  updatedAt          DateTime   @updatedAt

  // Relations
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([userId])
}

model TransactionGroup {
  id             String               @id @default(uuid())
  type           TransactionGroupType
  description    String
  idempotencyKey String               @unique // Prevents duplicate ledger posting
  createdAt      DateTime             @default(now())

  // Relations
  ledgerEntries  LedgerEntry[]
}

model LedgerEntry {
  id                 String           @id @default(uuid())
  transactionGroupId String
  partnerId          String?          // Null for system-level accounts
  userId             String?          // Null for partner or system-level accounts
  accountType        AccountType
  entryType          EntryType
  amount             Decimal          @db.Decimal(18, 4) // Always positive magnitude
  currency           String           @default("INR")
  createdAt          DateTime         @default(now())

  // Relations
  group              TransactionGroup @relation(fields: [transactionGroupId], references: [id], onDelete: Cascade)
  partner            Partner?         @relation(fields: [partnerId], references: [id])
  user               User?            @relation(fields: [userId], references: [id])

  // Isolation and auditing indexes
  @@index([transactionGroupId])
  @@index([userId, createdAt])
  @@index([partnerId, createdAt])
  @@index([transactionGroupId, entryType])
}

// ==========================================
// BUSINESS TELEMETRY (TRADES & CHECKOUTS)
// ==========================================

model Trade {
  id                       String      @id @default(uuid())
  userId                   String
  partnerId                String      // Tenant isolation anchor
  pair                     String      // e.g. "BTC/USDT"
  type                     TradeType
  entryPrice               Decimal     @db.Decimal(30, 10) // High precision for trading/crypto
  currentPrice             Decimal     @default(0.0) @db.Decimal(30, 10)
  quantity                 Decimal     @default(1.0) @db.Decimal(30, 10)
  exitPrice                Decimal     @default(0.0) @db.Decimal(30, 10)
  stopLoss                 Decimal     @db.Decimal(30, 10)
  target                   Decimal     @db.Decimal(30, 10)
  profit                   Decimal     @default(0.0) @db.Decimal(30, 10)
  pnl                      Decimal     @default(0.0) @db.Decimal(30, 10)
  status                   TradeStatus @default(ACTIVE)
  ledgerTransactionGroupId String?     @unique // Links to Ledger after trade close (for profit/loss credits)
  createdAt                DateTime    @default(now())
  closedAt                 DateTime?

  // Relations
  user                     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

// Tenant isolation & query index strategies
  @@index([userId])
  @@index([partnerId])
  @@index([partnerId, userId])
  @@index([partnerId, status])
  @@index([partnerId, createdAt])
}

model PaymentInitiation {
  id              String         @id @default(uuid())
  userId          String
  partnerId       String         // Tenant isolation anchor
  planId          String?
  amount          Decimal        @db.Decimal(18, 4)
  paymentGateway  String?        @default("usdt") @db.VarChar(50)
  paymentType     String?        @db.VarChar(20)
  status          String         @default("initiated") @db.VarChar(20)
  source          String?        // e.g. "Direct", "Referral", "Invest Now"
  checkoutOpenedAt DateTime      @default(now())
  lastActivityAt  DateTime       @default(now())
  completedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  processingAt    DateTime?      // Set when status = processing; used for crash recovery
  followUpStatus  FollowUpStatus @default(PENDING)
  contactedAt     DateTime?
  remarks         String?
  converted       Boolean        @default(false)

  // Relations
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan            Plan?          @relation(fields: [planId], references: [id])
  payment         Payment?

  // Indexes
  @@index([userId])
  @@index([partnerId])
  @@index([partnerId, status])
  @@index([partnerId, followUpStatus])
}

model Payment {
  id                       String        @id @default(uuid())
  userId                   String
  partnerId                String        // Tenant isolation anchor
  planName                 String
  amount                   Decimal       @db.Decimal(18, 4)
  currency                 String        @default("INR")
  paymentType              PaymentType   @default(USDT)
  network                  String?       // e.g. "TRC20"
  txnHash                  String?       // USDT Transaction hash
  utr                      String?       // UPI transaction reference
  screenshot               String?       // URL/Path to receipt image
  remark                   String?
  status                   PaymentStatus @default(PENDING)
  ledgerTransactionGroupId String?       @unique // Links to Ledger ONLY after APPROVAL status
  initiationId             String?       @unique
  idempotencyKey           String?       @unique
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  // Relations
  user                     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  initiation               PaymentInitiation? @relation(fields: [initiationId], references: [id], onDelete: SetNull)

  // Indexes for tenant verification tables
  @@index([userId])
  @@index([partnerId])
  @@index([partnerId, userId])
  @@index([partnerId, status])
}

model Withdrawal {
  id                       String           @id @default(uuid())
  withdrawalId             String           @unique // human readable reference e.g. WD-001001
  userId                   String
  partnerId                String           // Tenant isolation anchor
  amount                   Decimal          @db.Decimal(18, 4)
  currency                 String           @default("INR")
  status                   WithdrawalStatus @default(PENDING)
  ledgerTransactionGroupId String?          @unique // Links to Ledger after APPROVAL status
  method                   String?
  accountDetails           String?          // Stores serialized account info/bank details
  notes                    String?          // Optional user remarks
  processedAt              DateTime?
  processedBy              String?          // operator/admin responsible
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  // Relations
  user                     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([userId])
  @@index([partnerId])
  @@index([partnerId, status])
}

// ==========================================
// SECURITY, CONFIG & MARKETING
// ==========================================

model SecurityEvent {
  id          String    @id @default(uuid())
  adminId     String?   // Operator responsible
  userId      String?   // Target client
  partnerId   String?   // Tenant scope
  action      String    // e.g. "OTP_OVERRIDE", "USER_BLOCKED"
  reason      String
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())

  // Relations
  admin       Admin?    @relation(fields: [adminId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])

  // Auditing indexes
  @@index([partnerId, createdAt])
  @@index([userId, createdAt])
  @@index([adminId, createdAt])
}

model Referral {
  id                String         @id @default(cuid())
  partnerId         String
  referrerId        String         // User sharing link
  referredId        String         // Target registered user
  status            ReferralStatus @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  // Relations
  referrer          User           @relation("ReferrerToReferral", fields: [referrerId], references: [id])
  referredUser      User           @relation("ReferredToReferral", fields: [referredId], references: [id])
  reward            ReferralReward?

  // Indexes
  @@index([partnerId])
  @@index([referrerId])
  @@index([referredId])
}

model ReferralSettings {
  id                        String   @id @default(uuid())
  partnerId                 String?  @unique
  enabled                   Boolean  @default(false)
  commissionRate            Decimal  @default(10.00) @db.Decimal(5, 2)
  minimumDeposit            Decimal  @default(1000.00) @db.Decimal(18, 4)
  autoApprove               Boolean  @default(false)
  allowMultipleDeposits     Boolean  @default(false)
  commissionPayoutMode      String   @default("PENDING")
  maxReferralCommission     Decimal? @db.Decimal(18, 4)
  requireActiveSubscription Boolean  @default(true)
  requireReferrerDeposit    Boolean  @default(true)
  signupBonus               Decimal  @default(100.00) @db.Decimal(18, 4)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model Campaign {
  id          String   @id @default(uuid())
  partnerId   String
  name        String
  slug        String   // e.g. "SUMMER2025" for routing path /register?campaign=SUMMER2025
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([partnerId, slug])
  @@index([partnerId])
}

model SystemSettings {
  id                  String   @id @default(uuid())
  partnerId           String?  @unique // Null for global settings, populated for tenant overrides

  // Payment gateway config
  upiId               String?
  usdtAddress         String?
  usdtNetwork         String   @default("TRC20")
  upiEnabled          Boolean  @default(true)
  usdtEnabled         Boolean  @default(true)
  upiName             String?  @default("")
  upiQrCode           String?  @default("")
  usdtQrCode          String?  @default("")

  // Legacy fields kept for backward compat
  referralFeePct      Decimal  @default(10.00) @db.Decimal(5, 2)
  platformFeePct      Decimal  @default(30.00) @db.Decimal(5, 2)
  maintenance         Boolean  @default(false)
  individualProfitPct Decimal  @default(5.00) @db.Decimal(5, 2)
  clubProfitPct       Decimal  @default(7.00) @db.Decimal(5, 2)
  enableBulkDist      Boolean  @default(true)
  allowDuplicateDist  Boolean  @default(false)

  // Financial engine settings
  platformProfitCut            Decimal @default(30)   @db.Decimal(5, 2)
  referralBonusMultiplier      Decimal @default(100)  @db.Decimal(5, 2) // 100% = 1.0× factor (reward = base × multiplier/100)

  // Referral program
  referralEnabled                  Boolean @default(true)
  autoApproveReferralCommission    Boolean @default(true)
  referralCommissionRate           Decimal @default(10)   @db.Decimal(5, 2)
  minimumEligibleDeposit           Decimal @default(1000) @db.Decimal(18, 4)

  // Distribution controls
  enableBulkDistribution      Boolean @default(true)
  allowDuplicateWeeklyPayouts Boolean @default(false)

  // System
  maintenanceMode Boolean @default(false)

  updatedAt       DateTime @updatedAt
}

model Plan {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  subtitle     String
  capitalLabel String
  desc         String
  features     String[]
  btnText      String   @default("Get Started")
  status       String   @default("Active")
  isPopular    Boolean  @default(false)
  
  amount             Decimal?  @db.Decimal(18, 4)
  pricingType        String    @default("FIXED") @db.VarChar(20)
  weeklyProfit       Decimal   @default(5) @db.Decimal(5, 2)
  durationDays       Int       @default(30)
  sortOrder          Int       @default(0)
  isActive           Boolean   @default(true)
  platformFeePercent Decimal   @default(4.00) @db.Decimal(5, 2)
  referralEligible   Boolean   @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentInitiations PaymentInitiation[]
  userPlans          UserPlan[]
}

model TradeRecord {
  id          String   @id @default(cuid())
  pair        String
  side        String
  entryPrice  Float
  exitPrice   Float
  result      String
  profitLoss  Float
  tradeDate   DateTime
  notes       String?  @default("")
  status      String   @default("published")
  profitDistributed Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  distributionLog TradeDistributionLog?

  @@index([tradeDate])
  @@index([status])
}

model TradeDistributionLog {
  id              String   @id @default(cuid())
  tradeRecordId   String   @unique

  totalProfit     Decimal  @db.Decimal(18, 4)
  userCount       Int
  perUserProfit   Decimal  @db.Decimal(18, 4)

  status          String   @default("COMPLETED")

  createdAt       DateTime @default(now())

  tradeRecord     TradeRecord @relation(fields: [tradeRecordId], references: [id], onDelete: Cascade)
}

model ProfitDistribution {
  id               String             @id @default(cuid())
  reference        String             @unique
  userId           String
  planId           String?
  batchId          String?

  // All monetary values use Decimal — no Float
  investmentAmount Decimal            @default(0) @db.Decimal(18, 4)
  grossProfit      Decimal            @default(0) @db.Decimal(18, 4)
  platformCut      Decimal            @default(0) @db.Decimal(18, 4)
  netProfit        Decimal            @default(0) @db.Decimal(18, 4)
  weight           Decimal?           @db.Decimal(18, 4)

  type             String             @default("Weekly Profit")
  status           DistributionStatus @default(COMPLETED)
  note             String?            @default("")
  distributionDate DateTime           @default(now())
  weekKey          String             // e.g. "2025-W23"

  // Reversal audit
  reversedAt       DateTime?
  reversedBy       String?            // admin ID

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch            ProfitDistributionBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@unique([userId, weekKey])          // Idempotency guard — one payout per user per week
  @@index([userId])
  @@index([batchId])
  @@index([reference])
}

model ProfitDistributionBatch {
  id                  String             @id @default(cuid())
  createdBy           String
  totalProcessed      Int
  successCount        Int
  failedCount         Int
  skippedCount        Int
  dryRun              Boolean
  method              String             @default("EQUAL") // EQUAL or WEIGHTED
  createdAt           DateTime           @default(now())

  // Financial aggregates (Decimal — no Float)
  weekKey          String?
  totalInvestment  Decimal            @default(0) @db.Decimal(18, 4)
  totalGrossProfit Decimal            @default(0) @db.Decimal(18, 4)
  totalPlatformCut Decimal            @default(0) @db.Decimal(18, 4)
  totalNetProfit   Decimal            @default(0) @db.Decimal(18, 4)
  totalShares      Decimal?           @db.Decimal(18, 4)

  status           DistributionStatus @default(COMPLETED)

  // Reversal audit
  reversedAt       DateTime?
  reversedBy       String?            // admin ID

  profitDistributions ProfitDistribution[]
}

model GeneratedReport {
  id          String   @id @default(cuid())
  userId      String
  fileName    String
  reportType  String   // e.g. "TRADING", "PROFIT", "WALLET", "TAX"
  createdAt   DateTime @default(now())
  fileUrl     String

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Inquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    String   @default("PENDING") // PENDING, RESPONDED, CLOSED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
}

model InvestmentPlan {
  id            String           @id @default(uuid())
  partnerId     String
  name          String
  description   String?
  image         String?          @db.VarChar(500)
  minAmount     Decimal          @db.Decimal(18, 4)
  maxAmount     Decimal          @db.Decimal(18, 4)
  weeklyProfit  Decimal          @db.Decimal(5, 2)
  lockPeriod    Int              // Days
  referralBonus Decimal          @db.Decimal(5, 2)
  status        Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  partner       Partner          @relation(fields: [partnerId], references: [id])
  userInvestments UserInvestment[]

  @@index([partnerId])
}

model UserInvestment {
  id             String           @id @default(uuid())
  partnerId      String
  userId         String
  planId         String
  amount         Decimal          @db.Decimal(18, 4)
  profitRate     Decimal          @db.Decimal(5, 2)
  startDate      DateTime         @default(now())
  nextProfitDate DateTime
  status         InvestmentStatus @default(ACTIVE)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  partner        Partner          @relation(fields: [partnerId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan           InvestmentPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([userId])
}

model OtpSettings {
  id                 String      @id @default(cuid())
  emailOtpEnabled    Boolean     @default(true)
  otpLength          Int         @default(6)
  otpExpiryMinutes   Int         @default(10)
  supportContact     String      @default("+91 XXXXX XXXXX")
  updatedAt          DateTime    @updatedAt
}

// ==========================================
// NOTIFICATION SYSTEM
// ==========================================

model DeviceToken {
  id           String   @id @default(cuid())
  userId       String?
  adminId      String?
  token        String   @unique
  browser      String?
  platform     String?
  isActive     Boolean  @default(true)
  failureCount Int      @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin        Admin?   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([adminId])
  @@index([platform])
  @@index([isActive])
}

model Notification {
  id             String               @id @default(cuid())
  userId         String?              // Null represents broadcast or admin-only
  adminId        String?              // Null represents user-only
  partnerId      String?              // Multi-tenancy isolation
  title          String
  body           String
  type           NotificationEvent    // Event type Enum
  priority       NotificationPriority @default(MEDIUM)
  severity       NotificationSeverity @default(INFO)
  category       NotificationCategory
  status         NotificationStatus   @default(UNREAD)
  link           String?
  idempotencyKey String?              @unique
  metadata       Json?
  deletedAt      DateTime?            // Soft delete support
  createdAt      DateTime             @default(now())

  user           User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin          Admin?               @relation(fields: [adminId], references: [id], onDelete: Cascade)
  partner        Partner?             @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  deliveries     NotificationDelivery[]
  reads          NotificationRead[]
  actions        NotificationAction[]

  @@index([userId])
  @@index([adminId])
  @@index([partnerId])
  @@index([createdAt])
  @@index([type])
  @@index([category])
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime     @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([notificationId])
}

model NotificationAction {
  id             String       @id @default(cuid())
  notificationId String
  userId         String?
  adminId        String?
  actionType     String       // OPENED, CLICKED, DISMISSED
  clickedAt      DateTime     @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  admin          Admin?       @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@index([userId])
  @@index([adminId])
}

model NotificationDelivery {
  id             String                     @id @default(cuid())
  notificationId String
  channel        NotificationChannel
  status         NotificationDeliveryStatus @default(PENDING)
  error          String?
  retryCount     Int                        @default(0)
  lastRetryAt    DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime                   @default(now())

  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  @@index([notificationId])
  @@index([status])
  @@index([channel])
}

model NotificationSchedule {
  id          String                     @id @default(cuid())
  partnerId   String?
  title       String
  body        String
  event       NotificationEvent?
  audience    NotificationAudience
  scheduledAt DateTime
  status      NotificationScheduleStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt

  partner     Partner?                      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  channels    NotificationScheduleChannel[]

  @@index([partnerId])
}

model NotificationScheduleChannel {
  id          String               @id @default(cuid())
  scheduleId  String
  channel     NotificationChannel

  schedule    NotificationSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, channel])
}

model NotificationBroadcast {
  id                 String                        @id @default(cuid())
  partnerId          String?
  title              String
  body               String
  audience           NotificationAudience
  status             BroadcastStatus               @default(DRAFT)
  createdByAdminId   String
  approvedByAdminId  String?
  cancelledByAdminId String?
  totalUsers         Int                           @default(0)
  approvedAt         DateTime?
  rejectedAt         DateTime?
  cancelledAt        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?
  sentAt             DateTime?
  createdAt          DateTime                      @default(now())
  version            Int                           @default(1)
  approvalRequestId  String?                       @unique

  partner            Partner?                      @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  createdByAdmin     Admin                         @relation("BroadcastCreated", fields: [createdByAdminId], references: [id], onDelete: Cascade)
  approvedByAdmin    Admin?                        @relation("BroadcastApproved", fields: [approvedByAdminId], references: [id], onDelete: Cascade)
  cancelledByAdmin   Admin?                        @relation("BroadcastCancelled", fields: [cancelledByAdminId], references: [id], onDelete: Cascade)
  channels           NotificationBroadcastChannel[]
  execution          BroadcastExecution?

  @@index([partnerId])
  @@index([status])
  @@index([createdAt])
}

model NotificationBroadcastChannel {
  id          String                @id @default(cuid())
  broadcastId String
  channel     NotificationChannel

  broadcast   NotificationBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@unique([broadcastId, channel])
}

model BroadcastExecution {
  id              String    @id @default(cuid())
  broadcastId     String    @unique
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  lastHeartbeatAt DateTime?
  targetUsers     Int       @default(0)
  sentUsers       Int       @default(0)
  successCount    Int       @default(0)
  failedCount     Int       @default(0)
  skippedCount    Int       @default(0)
  chunkCount      Int       @default(0)
  durationMs      Int?

  broadcast       NotificationBroadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
}

model NotificationAdminAudit {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  entityType  String?
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  admin       Admin @relation("AdminNotificationAudits", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([createdAt])
}

model NotificationAnalytics {
  id         String   @id @default(cuid())
  partnerId  String?
  date       DateTime
  pushSent   Int      @default(0)
  emailSent  Int      @default(0)
  bellSent   Int      @default(0)
  socketSent Int      @default(0)
  smsSent    Int      @default(0)
  opened     Int      @default(0)
  clicked    Int      @default(0)
  read       Int      @default(0)
  dismissed  Int      @default(0)
  failed     Int      @default(0)
  createdAt  DateTime @default(now())

  partner    Partner? @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([date])
  @@unique([partnerId, date])
  @@index([partnerId])
}

model NotificationGlobalSetting {
  id            String   @id @default(cuid())
  pushEnabled   Boolean  @default(true)
  emailEnabled  Boolean  @default(true)
  socketEnabled Boolean  @default(true)
  bellEnabled   Boolean  @default(true)
  toastEnabled  Boolean  @default(true)
  smsEnabled    Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}

model NotificationEventSetting {
  id            String            @id @default(cuid())
  event         NotificationEvent @unique
  enabled       Boolean           @default(true)
  bellEnabled   Boolean           @default(true)
  pushEnabled   Boolean           @default(true)
  emailEnabled  Boolean           @default(true)
  toastEnabled  Boolean           @default(true)
  socketEnabled Boolean           @default(true)
  smsEnabled    Boolean           @default(false)
  updatedAt     DateTime          @updatedAt
}

model NotificationTemplate {
  id        String            @id @default(cuid())
  partnerId String?
  event     NotificationEvent
  channel   NotificationChannel
  version   Int               @default(1)
  title     String?           // custom title template
  body      String            // custom body template
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  partner   Partner?          @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@unique([event, channel, version])
  @@unique([partnerId, event, channel, version])
  @@index([partnerId])
}

model UserNotificationPreference {
  id           String               @id @default(cuid())
  userId       String
  category     NotificationCategory
  pushEnabled  Boolean              @default(true)
  emailEnabled Boolean              @default(true)
  bellEnabled  Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
}

model NotificationArchive {
  id             String    @id
  userId         String?
  adminId        String?
  partnerId      String?
  title          String
  body           String
  type           String
  priority       String
  severity       String
  category       String
  status         String
  link           String?
  idempotencyKey String?
  metadata       Json?
  createdAt      DateTime
  archivedAt     DateTime  @default(now())
}

// ==========================================
// PLAN ASSIGNMENT HISTORY
// ==========================================

model UserPlan {
  id        String    @id @default(cuid())
  userId    String
  planId    String
  active    Boolean   @default(true)
  startedAt DateTime  @default(now())
  expiresAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, active])
}

// ==========================================
// WALLET LEDGER (AUDIT TRAIL)
// ==========================================

model WalletLedger {
  id          String     @id @default(cuid())
  userId      String
  type        LedgerType
  entryType   EntryType
  amount      Decimal    @db.Decimal(18, 4)
  referenceId String?    // ProfitDistribution.id, Referral.id, Payment.id, etc.
  note        String?
  createdAt   DateTime   @default(now())

  @@index([userId])
  @@index([userId, type])
  @@index([referenceId])
}

// ==========================================
// FINANCIAL EVENT LOG (OPERATIONAL AUDIT)
// ==========================================

model FinancialEvent {
  id          String   @id @default(cuid())
  eventType   String   // PLAN_ASSIGNED, PROFIT_DISTRIBUTED, PROFIT_REVERSED, REFERRAL_APPROVED, etc.
  userId      String?
  actorId     String?  // Admin ID if admin-initiated
  referenceId String?  // batchId, paymentId, referralId, etc.
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([referenceId])
}

// ==========================================
// REFERRAL REWARDS (DUPLICATE PROTECTION)
// ==========================================

model ReferralReward {
  id                 String         @id @default(cuid())
  referralId         String         @unique
  referral           Referral       @relation(fields: [referralId], references: [id], onDelete: Cascade)
  paymentId          String?        @unique
  planId             String?
  planName           String?
  depositAmount      Decimal?       @db.Decimal(18, 4)
  platformFeePercent Decimal?       @db.Decimal(5, 2)
  platformFeeAmount  Decimal?       @db.Decimal(18, 4)
  referralRate       Decimal?       @db.Decimal(5, 2)
  commissionAmount   Decimal        @db.Decimal(18, 4)
  approvedBy         String?        // Admin ID
  approvedAt         DateTime?
  paidAt             DateTime?
  status             String
  createdAt          DateTime       @default(now())
}

model NotificationLog {
  id            String   @id @default(cuid())
  type          String   // e.g. "TOPIC_BROADCAST"
  topic         String?
  batchId       String?
  payload       Json
  status        String   // "SUCCESS" / "FAILED"
  attemptCount  Int      @default(1)
  lastAttemptAt DateTime?
  createdAt     DateTime @default(now())

  @@unique([batchId, type])
}

model ProfitDistributionLock {
  id                 String   @id @default(cuid())
  dateKey            String   @unique // e.g. '2023-10-25' or 'WEEK-42-2023'
  status             String   // RUNNING | COMPLETED | FAILED_RECONCILIATION
  startedAt          DateTime @default(now())
  endedAt            DateTime?
  lastProcessedIndex Int      @default(0)
}

